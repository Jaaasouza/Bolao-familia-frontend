# Base URL of the backend API. Use an absolute URL — never a relative /api path
# (Vercel SPA fallback would serve index.html for unknown paths).
#
# Local dev (backend running locally):
VITE_API_BASE=http://localhost:3000
#
# Production (Railway) — set this value in the Vercel project env vars at cutover:
# VITE_API_BASE=https://usam-fifa-world-cup-backend-production.up.railway.app

# --- Branding (optional; defaults to the USAM names) ---
# Override per deploy to brand a duplicated pool without touching code.
# VITE_APP_NAME    full display name (gate title, browser tab, install copy)
# VITE_BRAND       header big line
# VITE_BRAND_LINE2 header second line
# Example for a family pool:
# VITE_APP_NAME=Bolão da Família World Cup 2026
# VITE_BRAND=Bolão da Família
# VITE_BRAND_LINE2=World Cup 2026
